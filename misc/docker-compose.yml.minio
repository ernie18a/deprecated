version: '3'
services:
  minio:
    image: quay.io/minio/minio
    command: server /data --console-address ":9001" # a must
    ports:
      - "80:9001"
#     - "9000:9000" # api
#     - "9001:9001"
    volumes:
      - /MINIO:/data
    environment:
      - MINIO_ROOT_USER=333
      - MINIO_ROOT_PASSWORD=88888888
