version: '2'
services:
  web:
    image: ansible/awx_web:9.3.0
    container_name: awx_web
    depends_on:
      - rabbitmq
      - memcached
      - postgres
    ports:
      - "443:8052"
    hostname: awxweb
    user: root
    restart: unless-stopped
    volumes:
      - "./backups:/var/lib/awx/backups:rw"
      - "./configs/SECRET_KEY:/etc/tower/SECRET_KEY"
      - "./configs/credentials.py:/etc/tower/conf.d/credentials.py"
      - "./configs/environment.sh:/etc/tower/conf.d/environment.sh"
      - "./configs/nginx/nginx.conf:/etc/nginx/nginx.conf:ro"
      - "./configs/nginx/ssl:/etc/nginx/ssl:ro"
      - "./projects:/var/lib/awx/projects:rw"
      - "./reports:/var/lib/awx/reports:rw"
      - "./scripts:/var/lib/awx/scripts:rw"
      - "./roles:/var/lib/awx/.ansible/roles:rw"
    environment:
      http_proxy: 
      https_proxy: 
      no_proxy:
    logging:
      driver: syslog
      options:
        syslog-address: "udp://127.0.0.1:514"
        syslog-facility: "16"
        tag: "awx-web" 
  task:
    image: ansible/awx_task:9.3.0
    container_name: awx_task
    depends_on:
      - rabbitmq
      - memcached
      - web
      - postgres
    hostname: awx
    user: root
    restart: unless-stopped
    volumes:
      - "./backups:/var/lib/awx/backups:rw"
      - "./configs/SECRET_KEY:/etc/tower/SECRET_KEY"
      - "./configs/credentials.py:/etc/tower/conf.d/credentials.py"
      - "./configs/environment.sh:/etc/tower/conf.d/environment.sh"
      - "./projects:/var/lib/awx/projects:rw"
      - "./reports:/var/lib/awx/reports:rw"
      - "./scripts:/var/lib/awx/scripts:rw"
      - "./roles:/var/lib/awx/.ansible/roles:rw"
    environment:
      http_proxy: 
      https_proxy: 
      no_proxy:
    logging:
      driver: syslog
      options:
        syslog-address: "udp://127.0.0.1:514"
        syslog-facility: "16"
        tag: "awx-task"   
  rabbitmq:
    image: ansible/awx_rabbitmq:3.7.4
    container_name: awx_rabbitmq
    restart: unless-stopped
    environment:
      RABBITMQ_DEFAULT_VHOST: "awx"
      RABBITMQ_DEFAULT_USER: "guest"
      RABBITMQ_DEFAULT_PASS: "awxpass"
      RABBITMQ_ERLANG_COOKIE: cookiemonster
      http_proxy: 
      https_proxy: 
      no_proxy:
    logging:
      driver: syslog
      options:
        syslog-address: "udp://127.0.0.1:514"
        syslog-facility: "16"
        tag: "rabbitmq"   
  memcached:
    image: "memcached:alpine"
    container_name: awx_memcached
    restart: unless-stopped
    environment:
      http_proxy: 
      https_proxy: 
      no_proxy:
    logging:
      driver: syslog
      options:
        syslog-address: "udp://127.0.0.1:514"
        syslog-facility: "16"
        tag: "memcached"    
  postgres:
    image: postgres:10
    container_name: awx_postgres
    restart: unless-stopped
    volumes:
      - ./pg:/var/lib/postgresql/data/pgdata:Z
    environment:
      POSTGRES_USER: awx
      POSTGRES_PASSWORD: awxpass
      POSTGRES_DB: awx
      PGDATA: /var/lib/postgresql/data/pgdata
      http_proxy: 
      https_proxy: 
      no_proxy: 
    logging:
      driver: syslog
      options:
        syslog-address: "udp://127.0.0.1:514"
        syslog-facility: "16"
        tag: "postgres"
