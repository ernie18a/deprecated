version: "3"
services:
  jenkins:
    image:  jenkins/jenkins
#   image:  jenkins/jenkins:lts 
    container_name: jenkins
    logging:
      driver: "json-file"
      options:
        max-size: "200k"
        max-file: "10"
#   volumes:
#     - /var/BBBB/jenkins_home:/var/jenkins_home
#     - /etc/localtime:/etc/localtime:ro
    ports:
      - "8080:8080"
      - "50000:50000" # host:container
